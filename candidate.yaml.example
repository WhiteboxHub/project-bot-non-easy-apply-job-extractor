# Candidate Marketing Configuration Example
# Use this file to manage candidates for the Job Extraction Scheduler
# Copy this to 'candidate.yaml' and update with your actual data.

# Global Settings (Used if not specified in candidate block)
settings:
  distance_miles: 50
  default_location: "United States"
  search_timespan: "24h" # Options: 24h, 7d
  default_keywords: ["AI Engineer", "Software Engineer"]
  dry_run: false
  validate_secrets_at_startup: true
  jobs_per_location_limit: 99
  total_run_limit: 999
  distance_buckets: [5, 10, 25, 50]
  wait_time_between_locations: 5

candidates:
  - candidate_id: "example_001"
    name: "Example User"
    linkedin_username: "user@example.com"
    linkedin_password: "your_password_here"
    
    # Job Keywords for matching search results
    keywords:
      - "AI Engineer"
      
    # Strict Title Filters (extracted job title MUST match one of these)
    title_filters:
      - "Artificial Intelligence"
      - "Machine Learning"
      - "AI"
      
    # Job Type Filters (e.g., Full-time, Contract, Part-time)
    job_type_filters:
      - "Full-time"
      - "Contract"
    
    # Locations (optional list of Zipcodes)
    locations:
      # - "90210"
      # - "10001"
    
    run_extract_linkedin_jobs: true
