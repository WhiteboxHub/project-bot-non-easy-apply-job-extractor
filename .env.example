# Website API Credentials
SECRET_KEY=your_secret_key_here

## Local testing override - set to true to use LOCAL_WBL_API_URL instead of production
USE_LOCAL_API=false
LOCAL_WBL_API_URL=http://localhost:8000/api

# Using production API
WBL_API_URL=https://api.whitebox-learning.com/api

# API Credentials for login
API_EMAIL=your_email@example.com
API_PASSWORD=your_password_here
API_TOKEN=

# Bot Extraction Settings
DISTANCE_MILES=50
DEFAULT_KEYWORDS="AI And Engineer,LLM And Engineer"
BLACKLIST_WORDS="java,network,recruiter,devops"  # Example values
SCHEDULER_TIME="09:00"

# Workflow Configuration
WORKFLOW_KEY=linkedin_non_easy_job_extractor
WORKFLOW_ID=8

# Execution Mode
DRY_RUN=false
VALIDATE_SECRETS_AT_STARTUP=true
